{
    "name": "hyper-express",
    "version": "7.0.2",
    "description": "High performance Node.js webserver with a simple-to-use API powered by uWebsockets.js under the hood.",
    "main": "index.js",
    "types": "./types/index.d.ts",
    "files": [
        "index.js",
        "src/",
        "types/"
    ],
    "engines": {
        "node": ">=22 <23 || >=24 <25 || >=26 <27"
    },
    "scripts": {
        "test": "node --test --test-concurrency=1 tests/index.js",
        "test:types": "tsc --noEmit --pretty false",
        "test:load": "node --expose-gc tests/load.js",
        "benchmark:v7": "node benchmarks/v7/compare.cjs"
    },
    "repository": {
        "type": "git",
        "url": "git+ssh://git@github.com/kartikk221/hyper-express.git"
    },
    "keywords": [
        "uws",
        "websockets",
        "uwebsocketsjs",
        "express",
        "expressjs",
        "fast",
        "http-server",
        "https-server",
        "http",
        "https",
        "sse",
        "events",
        "streaming",
        "stream",
        "upload",
        "file",
        "multipart",
        "ws",
        "websocket",
        "performance",
        "router"
    ],
    "author": "Kartik Kumar",
    "license": "MIT",
    "bugs": {
        "url": "https://github.com/kartikk221/hyper-express/issues"
    },
    "homepage": "https://github.com/kartikk221/hyper-express#readme",
    "dependencies": {
        "@types/busboy": "^1.5.4",
        "@types/range-parser": "^1.2.7",
        "busboy": "^1.6.0",
        "cookie": "^1.1.1",
        "cookie-signature": "^1.2.2",
        "mime-types": "^2.1.35",
        "negotiator": "^1.0.0",
        "range-parser": "^1.3.0",
        "type-is": "^1.6.18",
        "uWebSockets.js": "github:uNetworking/uWebSockets.js#v20.69.0"
    },
    "devDependencies": {
        "@types/express": "^5.0.6",
        "@types/node": "^26.0.0",
        "abort-controller": "^3.0.0",
        "eventsource": "^2.0.0",
        "form-data": "^4.0.0",
        "node-fetch": "^2.7.0",
        "typescript": "^5.9.3",
        "uid-safe": "^2.1.5",
        "ws": "^8.18.3"
    }
}
